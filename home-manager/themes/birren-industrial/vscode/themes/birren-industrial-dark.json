{
  "name": "Birren Industrial Dark",
  "type": "dark",
  "colors": {
    // Editor Colors
    "editor.background": "#2a2a28",
    "editor.foreground": "#e8e0d5",
    "editorLineNumber.foreground": "#6b6b68",
    "editorLineNumber.activeForeground": "#7fb5a0",
    "editorCursor.foreground": "#7fb5a0",
    "editor.selectionBackground": "#5a8a7340",
    "editor.inactiveSelectionBackground": "#5a8a7320",
    "editor.lineHighlightBackground": "#3a3a38",
    "editor.lineHighlightBorder": "#00000000",
    "editorWhitespace.foreground": "#6b6b6840",
    "editorIndentGuide.background1": "#6b6b6840",
    "editorIndentGuide.activeBackground1": "#7fb5a080",
    "editor.findMatchBackground": "#f2b63260",
    "editor.findMatchHighlightBackground": "#f2b63240",
    "editor.findRangeHighlightBackground": "#7fb5a020",
    "editor.wordHighlightBackground": "#7fb5a030",
    "editor.wordHighlightStrongBackground": "#7fb5a050",
    "editorBracketMatch.background": "#7fb5a040",
    "editorBracketMatch.border": "#7fb5a0",
    // Sidebar
    "sideBar.background": "#2a2a28",
    "sideBar.foreground": "#e8e0d5",
    "sideBar.border": "#6b6b68",
    "sideBarTitle.foreground": "#7fb5a0",
    "sideBarSectionHeader.background": "#3a3a38",
    "sideBarSectionHeader.foreground": "#7fb5a0",
    "sideBarSectionHeader.border": "#6b6b68",
    // Activity Bar
    "activityBar.background": "#2a2a28",
    "activityBar.foreground": "#7fb5a0",
    "activityBar.inactiveForeground": "#6b6b68",
    "activityBar.border": "#6b6b68",
    "activityBarBadge.background": "#d67d3e",
    "activityBarBadge.foreground": "#e8e0d5",
    // Status Bar
    "statusBar.background": "#2a2a28",
    "statusBar.foreground": "#e8e0d5",
    "statusBar.border": "#6b6b68",
    "statusBar.debuggingBackground": "#d67d3e",
    "statusBar.debuggingForeground": "#2a2a28",
    "statusBar.noFolderBackground": "#2a2a28",
    "statusBarItem.remoteBackground": "#5b7a8e",
    "statusBarItem.remoteForeground": "#e8e0d5",
    // Title Bar
    "titleBar.activeBackground": "#2a2a28",
    "titleBar.activeForeground": "#e8e0d5",
    "titleBar.inactiveBackground": "#2a2a28",
    "titleBar.inactiveForeground": "#6b6b68",
    "titleBar.border": "#6b6b68",
    // Tabs
    "tab.activeBackground": "#2a2a28",
    "tab.activeForeground": "#7fb5a0",
    "tab.activeBorder": "#7fb5a0",
    "tab.activeBorderTop": "#00000000",
    "tab.inactiveBackground": "#3a3a38",
    "tab.inactiveForeground": "#a69f95",
    "tab.border": "#6b6b68",
    "tab.hoverBackground": "#3a3a38",
    "tab.hoverForeground": "#7fb5a0",
    // Panel
    "panel.background": "#2a2a28",
    "panel.border": "#6b6b68",
    "panelTitle.activeBorder": "#7fb5a0",
    "panelTitle.activeForeground": "#7fb5a0",
    "panelTitle.inactiveForeground": "#a69f95",
    // Terminal
    "terminal.background": "#2a2a28",
    "terminal.foreground": "#e8e0d5",
    "terminal.ansiBlack": "#2a2a28",
    "terminal.ansiRed": "#c83e3a",
    "terminal.ansiGreen": "#7fb5a0",
    "terminal.ansiYellow": "#f2b632",
    "terminal.ansiBlue": "#5b7a8e",
    "terminal.ansiMagenta": "#8b5a3c",
    "terminal.ansiCyan": "#7fb5a0",
    "terminal.ansiWhite": "#e8e0d5",
    "terminal.ansiBrightBlack": "#6b6b68",
    "terminal.ansiBrightRed": "#d67d3e",
    "terminal.ansiBrightGreen": "#5a8a73",
    "terminal.ansiBrightYellow": "#c9b89a",
    "terminal.ansiBrightBlue": "#7fb5a0",
    "terminal.ansiBrightMagenta": "#a69f95",
    "terminal.ansiBrightCyan": "#7fb5a0",
    "terminal.ansiBrightWhite": "#e8e0d5",
    // Lists and Trees
    "list.activeSelectionBackground": "#5a8a73",
    "list.activeSelectionForeground": "#e8e0d5",
    "list.inactiveSelectionBackground": "#5a8a7340",
    "list.hoverBackground": "#3a3a38",
    "list.hoverForeground": "#7fb5a0",
    "list.focusBackground": "#5a8a7360",
    "list.focusForeground": "#e8e0d5",
    "list.highlightForeground": "#7fb5a0",
    // Buttons
    "button.background": "#7fb5a0",
    "button.foreground": "#2a2a28",
    "button.hoverBackground": "#5a8a73",
    // Input
    "input.background": "#3a3a38",
    "input.border": "#6b6b68",
    "input.foreground": "#e8e0d5",
    "input.placeholderForeground": "#6b6b68",
    "inputOption.activeBorder": "#7fb5a0",
    "inputValidation.errorBackground": "#c83e3a40",
    "inputValidation.errorBorder": "#c83e3a",
    "inputValidation.warningBackground": "#d67d3e40",
    "inputValidation.warningBorder": "#d67d3e",
    "inputValidation.infoBackground": "#5b7a8e40",
    "inputValidation.infoBorder": "#5b7a8e",
    // Dropdown
    "dropdown.background": "#3a3a38",
    "dropdown.border": "#6b6b68",
    "dropdown.foreground": "#e8e0d5",
    // Badges
    "badge.background": "#d67d3e",
    "badge.foreground": "#2a2a28",
    // Scrollbar
    "scrollbarSlider.background": "#6b6b6880",
    "scrollbarSlider.hoverBackground": "#6b6b68cc",
    "scrollbarSlider.activeBackground": "#a69f95",
    // Notifications
    "notificationCenter.border": "#6b6b68",
    "notifications.background": "#3a3a38",
    "notifications.border": "#6b6b68",
    "notifications.foreground": "#e8e0d5",
    "notificationLink.foreground": "#7fb5a0",
    // Breadcrumbs
    "breadcrumb.background": "#2a2a28",
    "breadcrumb.foreground": "#a69f95",
    "breadcrumb.focusForeground": "#7fb5a0",
    "breadcrumb.activeSelectionForeground": "#7fb5a0",
    "breadcrumbPicker.background": "#3a3a38",
    // Git Decorations
    "gitDecoration.addedResourceForeground": "#7fb5a0",
    "gitDecoration.modifiedResourceForeground": "#d67d3e",
    "gitDecoration.deletedResourceForeground": "#c83e3a",
    "gitDecoration.untrackedResourceForeground": "#f2b632",
    "gitDecoration.ignoredResourceForeground": "#6b6b68",
    "gitDecoration.conflictingResourceForeground": "#f2b632",
    // Diff Editor
    "diffEditor.insertedTextBackground": "#7fb5a020",
    "diffEditor.removedTextBackground": "#c83e3a20",
    // Peek View
    "peekView.border": "#7fb5a0",
    "peekViewEditor.background": "#3a3a38",
    "peekViewResult.background": "#2a2a28",
    "peekViewTitle.background": "#3a3a38",
    // Merge Conflicts
    "merge.currentHeaderBackground": "#7fb5a040",
    "merge.incomingHeaderBackground": "#5b7a8e40",
    "editorOverviewRuler.currentContentForeground": "#7fb5a0",
    "editorOverviewRuler.incomingContentForeground": "#5b7a8e"
  },
  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#5b7a8e",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#7fb5a0"
      }
    },
    {
      "name": "String Escape",
      "scope": [
        "constant.character.escape",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#5a8a73"
      }
    },
    {
      "name": "Number",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null"
      ],
      "settings": {
        "foreground": "#c83e3a"
      }
    },
    {
      "name": "Constant",
      "scope": [
        "constant",
        "constant.language"
      ],
      "settings": {
        "foreground": "#c83e3a"
      }
    },
    {
      "name": "Keyword",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#d67d3e"
      }
    },
    {
      "name": "Operator",
      "scope": [
        "keyword.operator",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#a69f95"
      }
    },
    {
      "name": "Function",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#f2b632"
      }
    },
    {
      "name": "Class/Type",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#5b7a8e"
      }
    },
    {
      "name": "Variable",
      "scope": [
        "variable",
        "variable.other",
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#e8e0d5"
      }
    },
    {
      "name": "Property",
      "scope": [
        "variable.other.property",
        "variable.other.object.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#a69f95"
      }
    },
    {
      "name": "Tag",
      "scope": [
        "entity.name.tag",
        "meta.tag"
      ],
      "settings": {
        "foreground": "#d67d3e"
      }
    },
    {
      "name": "Attribute",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#8b5a3c"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation.definition",
        "punctuation.section",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#a69f95"
      }
    },
    {
      "name": "Markup Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#d67d3e",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markup Heading",
      "scope": [
        "markup.heading"
      ],
      "settings": {
        "foreground": "#7fb5a0",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markup Link",
      "scope": [
        "markup.underline.link"
      ],
      "settings": {
        "foreground": "#5b7a8e"
      }
    },
    {
      "name": "Markup Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#7fb5a0"
      }
    },
    {
      "name": "Invalid",
      "scope": [
        "invalid",
        "invalid.illegal"
      ],
      "settings": {
        "foreground": "#c83e3a"
      }
    }
  ]
}
